// TaskFlow Prisma schema
// Docs: https://pris.ly/d/prisma-schema

// The generator tells Prisma what kind of client to create.
// "prisma-client-js" is the classic client you import via "@prisma/client".
generator client {
  provider = "prisma-client-js"
}

// The datasource is your database connection.
// The URL is read from the DATABASE_URL variable in your .env file.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection in prod (direct works locally)
  directUrl = env("DIRECT_URL")   // direct connection — used for migrations
}

// A registered user. One user has many tasks.
model User {
  id       String @id @default(cuid())
  email    String @unique
  password String // bcrypt HASH, never the plain password
  tasks    Task[]
}

// A single to-do item that belongs to one user.
model Task {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
